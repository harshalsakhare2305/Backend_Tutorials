{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",        // ⭐ ensures output goes to dist
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],        // ⭐ prevents prisma.config.ts issue
  "exclude": ["node_modules", "dist"]
}